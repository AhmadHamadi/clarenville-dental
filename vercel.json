{
  "trailingSlash": false,
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": false },
    { "source": "/:slug.html", "destination": "/:slug", "permanent": false },
    { "source": "/pages/:slug.html", "destination": "/:slug", "permanent": false },
    { "source": "/pages/:slug", "destination": "/:slug", "permanent": false }
  ],
  "rewrites": [
    { "source": "/:slug", "destination": "/pages/:slug.html" }
  ]
}
